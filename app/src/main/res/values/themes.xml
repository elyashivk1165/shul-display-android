<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ShulDisplay" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <!-- Black window background — Light parent gave us white. Any sliver
             of background still showing through (system bars during a focus
             flash, layout race during recreate) renders as black, not white. -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
    </style>

    <style name="Theme.ShulDisplay.Fullscreen" parent="Theme.ShulDisplay">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <!-- Disable the system's automatic contrast scrim behind the nav bar
             (Android Q+). Without this, even a hidden bar can leave a faint
             strip on devices that draw the contrast layer. -->
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <!-- Allow drawing into display cutout area too — extra screen real-estate. -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <style name="Theme.ShulDisplay.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowElevation">24dp</item>
    </style>
</resources>
